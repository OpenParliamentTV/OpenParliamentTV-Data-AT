                }
              ],
              "text": "Ich eröffne die 66. Sitzung des Nationalrates."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Franz Leonhard Eßl , Mag.",
                  "timeStart": "4.620",
                  "timeEnd": "9.160",
                  "entities": [
                    {
                      "label": "Franz Leonhard Eßl",
