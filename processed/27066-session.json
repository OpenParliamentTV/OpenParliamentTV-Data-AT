                      "score": 0.9854
                    }
                  ]
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Franz Leonhard Eßl , Mag. Michael Hammer , Klaus Köchl , Bedrana Ribo, MA und Süleyman Zorba ."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisung",
                  "timeStart": "12.800",
                  "timeEnd": "13.440",
                  "entities": []
                }
              ],
              "text": "Zuweisung"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich weise die Regierungsvorlage (484 der Beilagen) betreffend Bundesfinanzrahmengesetz 2021 bis 2024 dem Budgetausschuss zu.",
                  "timeStart": "13.440",
                  "timeEnd": "21.960",
                  "entities": []
                }
              ],
              "text": "Ich weise die Regierungsvorlage (484 der Beilagen) betreffend Bundesfinanzrahmengesetz 2021 bis 2024 dem Budgetausschuss zu."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Donnerstag, 26.11.2020, 8.30 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen.",
                  "timeStart": "21.960",
                  "timeEnd": "30.460",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Donnerstag, 26.11.2020, 8.30 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich danke nach einer sehr intensiven und ausgedehnten Sitzungswoche allen MitarbeiterInnen der Parlamentsdirektion, vor allem jenen hier am Nationalratspräsidium, die wirklich hervorragende Arbeit geleistet haben, und auch jenen des Sicherheitsdienstes, sehr herzlich, diese haben sich das wahrlich verdient, und wünsche Ihnen ein gutes Nachhausekommen. (",
                  "timeStart": "30.460",
                  "timeEnd": "42.640",
                  "entities": [
                    {
                      "label": "Parlamentsdirektion",
                      "wid": "Q4817650",
                      "wtype": "ORG",
                      "score": 0.7934
                    }
                  ]
                },
                {
                  "text": "Allgemeiner Beifall.)",
                  "timeStart": "42.640",
                  "timeEnd": "43.640",
                  "entities": []
                }
              ],
              "text": "Ich danke nach einer sehr intensiven und ausgedehnten Sitzungswoche allen MitarbeiterInnen der Parlamentsdirektion, vor allem jenen hier am Nationalratspräsidium, die wirklich hervorragende Arbeit geleistet haben, und auch jenen des Sicherheitsdienstes, sehr herzlich, diese haben sich das wahrlich verdient, und wünsche Ihnen ein gutes Nachhausekommen. (Allgemeiner Beifall.)"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "43.640",
                  "timeEnd": "45.960",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
