                      "score": 0.965
                    }
                  ]
                },
                {
                  "text": "Michael Hammer , Klaus Köchl , Bedrana Ribo, MA und Süleyman Zorba .",
                  "timeStart": "9.160",
                  "timeEnd": "12.800",
                  "entities": [
                    {
