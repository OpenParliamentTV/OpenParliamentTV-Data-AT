          "textBody": [
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich eröffne die 261. Sitzung des Nationalrates.",
                  "timeStart": "1.000",
                  "timeEnd": "2.840"
                }
              ],
              "text": "Ich eröffne die 261. Sitzung des Nationalrates."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Franz Hörl , MMst.",
                  "timeStart": "2.840",
                  "timeEnd": "5.160"
                },
                {
                  "text": "Mag. (",
                  "timeStart": "5.160",
                  "timeEnd": "5.360"
                },
                {
                  "text": "FH) Maria Neumann , Petra Bayr, MA MLS , Christian Hafenecker, MA , Mag.",
                  "timeStart": "5.360",
                  "timeEnd": "6.040"
                },
                {
                  "text": "Eva Blimlinger und Mag.",
                  "timeStart": "6.040",
                  "timeEnd": "6.040"
                },
                {
                  "text": "Agnes Sirkka Prammer .",
                  "timeStart": "6.040",
                  "timeEnd": "6.440"
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Franz Hörl , MMst. Mag. (FH) Maria Neumann , Petra Bayr, MA MLS , Christian Hafenecker, MA , Mag. Eva Blimlinger und Mag. Agnes Sirkka Prammer ."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Einlauf und Zuweisungen",
                  "timeStart": "6.440",
                  "timeEnd": "6.960"
                }
              ],
              "text": "Einlauf und Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungsaal verteilte Mitteilung.",
                  "timeStart": "6.960",
                  "timeEnd": "9.720"
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungsaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "9.720",
                  "timeEnd": "10.920"
                }
              ],
              "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen:",
                  "timeStart": "10.920",
                  "timeEnd": "11.120"
                }
              ],
              "text": "Zuweisungen:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "11.120",
                  "timeEnd": "12.040"
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "zur Vorberatung:",
                  "timeStart": "12.040",
                  "timeEnd": "12.280"
                }
              ],
              "text": "zur Vorberatung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ausschuss für Arbeit und Soziales:",
                  "timeStart": "12.280",
                  "timeEnd": "13.000"
                }
              ],
              "text": "Ausschuss für Arbeit und Soziales:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Ausländerbeschäftigungsgesetz, das Niederlassungs- und Aufenthaltsgesetz, das Asylgesetz 2005 und das Ausbildungspflichtgesetz geändert werden ( 2528 d.B. )",
                  "timeStart": "13.000",
                  "timeEnd": "16.800"
                }
              ],
              "text": "Bundesgesetz, mit dem das Ausländerbeschäftigungsgesetz, das Niederlassungs- und Aufenthaltsgesetz, das Asylgesetz 2005 und das Ausbildungspflichtgesetz geändert werden ( 2528 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Budgetausschuss:",
                  "timeStart": "16.800",
                  "timeEnd": "17.200"
                }
              ],
              "text": "Budgetausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz betreffend die Ermächtigung zur Verfügung über bewegliches Bundesvermögen ( 2529 d.B. )",
                  "timeStart": "17.200",
                  "timeEnd": "21.360"
                }
              ],
              "text": "Bundesgesetz betreffend die Ermächtigung zur Verfügung über bewegliches Bundesvermögen ( 2529 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Gesundheitsausschuss:",
                  "timeStart": "21.360",
                  "timeEnd": "21.440"
                }
              ],
              "text": "Gesundheitsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Gesundheitstelematikgesetz 2012, das Allgemeine Sozialversicherungsgesetz, das Epidemiegesetz 1950, das Patientenverfügungs-Gesetz und das Suchtmittelgesetz geändert werden ( 2530 d.B. )",
                  "timeStart": "21.440",
                  "timeEnd": "26.080"
                }
              ],
              "text": "Bundesgesetz, mit dem das Gesundheitstelematikgesetz 2012, das Allgemeine Sozialversicherungsgesetz, das Epidemiegesetz 1950, das Patientenverfügungs-Gesetz und das Suchtmittelgesetz geändert werden ( 2530 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 15. Mai, 9 Uhr, in Aussicht genommen wird, wird auf schriftlichem Wege einberufen.",
                  "timeStart": "26.080",
                  "timeEnd": "28.920"
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 15. Mai, 9 Uhr, in Aussicht genommen wird, wird auf schriftlichem Wege einberufen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Weiters darf ich bekannt geben, dass im Anschluss an diese Sitzung der Cofag-Untersuchungsausschuss und der Rot-blauer-Machtmissbrauch-Untersuchungsausschuss – jeweils im Lokal Hansen – zusammentreten.",
                  "timeStart": "28.920",
                  "timeEnd": "39.880"
                }
              ],
              "text": "Weiters darf ich bekannt geben, dass im Anschluss an diese Sitzung der Cofag-Untersuchungsausschuss und der Rot-blauer-Machtmissbrauch-Untersuchungsausschuss – jeweils im Lokal Hansen – zusammentreten."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "39.880",
                  "timeEnd": "41.560"
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
        }
