                    }
                  ]
                }
              ],
              "text": "Bundesgesetz, mit dem das Ausländerbeschäftigungsgesetz, das Niederlassungs- und Aufenthaltsgesetz, das Asylgesetz 2005 und das Ausbildungspflichtgesetz geändert werden ( 2528 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Budgetausschuss:",
                  "timeStart": "20.680",
                  "timeEnd": "20.920",
                  "entities": []
                }
              ],
              "text": "Budgetausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz betreffend die Ermächtigung zur Verfügung über bewegliches Bundesvermögen ( 2529 d.B. )",
                  "timeStart": "20.920",
                  "timeEnd": "23.520",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz betreffend die Ermächtigung zur Verfügung über bewegliches Bundesvermögen ( 2529 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Gesundheitsausschuss:",
                  "timeStart": "23.520",
                  "timeEnd": "24.680",
                  "entities": []
                }
              ],
              "text": "Gesundheitsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Gesundheitstelematikgesetz 2012, das Allgemeine Sozialversicherungsgesetz, das Epidemiegesetz 1950, das Patientenverfügungs-Gesetz und das Suchtmittelgesetz geändert werden ( 2530 d.B. )",
                  "timeStart": "24.680",
                  "timeEnd": "32.600",
                  "entities": [
                    {
                      "label": "Bundesgesetz",
                      "wid": "Q476068",
                      "wtype": "MISC",
                      "score": 0.0943
                    },
                    {
                      "label": "Allgemeine Sozialversicherungsgesetz",
                      "wid": "Q2648987",
                      "wtype": "MISC",
                      "score": 0.9782
                    },
                    {
                      "label": "Epidemiegesetz",
                      "wid": "Q314676",
