              ],
              "text": "Weiters weise ich den Antrag 2838/A dem Ausschuss für Wirtschaft, Industrie und Energie und die Anträge 2839/A und 2840/A dem Budgetausschuss zu."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Fristsetzungsantrag",
                  "timeStart": "51.800",
                  "timeEnd": "52.320",
                  "entities": []
                }
              ],
              "text": "Fristsetzungsantrag"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich darf mitteilen, dass ein Fristsetzungsantrag eingelangt ist.",
                  "timeStart": "52.320",
                  "timeEnd": "53.720",
                  "entities": []
                },
                {
                  "text": "Die Abgeordneten Mag.",
                  "timeStart": "53.720",
                  "timeEnd": "54.080",
                  "entities": []
                },
                {
                  "text": "Dr. Rudolf Taschner und Mag.",
                  "timeStart": "54.080",
                  "timeEnd": "54.240",
                  "entities": []
                },
                {
                  "text": "Sibylle Hamann haben beantragt, dem Unterrichtsausschuss zur Berichterstattung über die Regierungsvorlage 1696 der Beilagen eine Frist bis zum 11. Oktober zu setzen.",
                  "timeStart": "54.240",
                  "timeEnd": "58.080",
                  "entities": [
                    {
                      "label": "Sibylle Hamann",
                      "wid": "Q1751948",
                      "wtype": "PER",
                      "score": 0.9899
                    }
                  ]
                }
              ],
              "text": "Ich darf mitteilen, dass ein Fristsetzungsantrag eingelangt ist. Die Abgeordneten Mag. Dr. Rudolf Taschner und Mag. Sibylle Hamann haben beantragt, dem Unterrichtsausschuss zur Berichterstattung über die Regierungsvorlage 1696 der Beilagen eine Frist bis zum 11. Oktober zu setzen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Der gegenständliche Fristsetzungsantrag wird gemäß der Geschäftsordnung nach Beendigung der Verhandlungen in dieser Sitzung, also sogleich, zur Abstimmung gebracht.",
                  "timeStart": "58.080",
                  "timeEnd": "59.960",
                  "entities": []
                }
              ],
              "text": "Der gegenständliche Fristsetzungsantrag wird gemäß der Geschäftsordnung nach Beendigung der Verhandlungen in dieser Sitzung, also sogleich, zur Abstimmung gebracht."
            }
          ]
        }
