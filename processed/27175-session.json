                  "entities": []
                }
              ],
              "text": "Abstimmung über einen Fristsetzungsantrag"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Wir kommen zur Abstimmung über den Antrag der Abgeordneten Taschner und Hamann, dem Unterrichtsausschuss zur Berichterstattung über die Regierungsvorlage 1696 der Beilagen eine Frist bis zum 11. Oktober 2022 zu setzen.",
                  "timeStart": "1.940",
                  "timeEnd": "13.920",
                  "entities": []
                }
              ],
              "text": "Wir kommen zur Abstimmung über den Antrag der Abgeordneten Taschner und Hamann, dem Unterrichtsausschuss zur Berichterstattung über die Regierungsvorlage 1696 der Beilagen eine Frist bis zum 11. Oktober 2022 zu setzen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Wer dafür ist, den bitte ich um ein Zeichen. –",
                  "timeStart": "13.920",
                  "timeEnd": "16.120",
                  "entities": []
                },
                {
                  "text": "Das ist die Mehrheit, angenommen.",
                  "timeStart": "16.120",
                  "timeEnd": "18.400",
                  "entities": []
                }
              ],
              "text": "Wer dafür ist, den bitte ich um ein Zeichen. – Das ist die Mehrheit, angenommen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates berufe ich für Dienstag, den 4. Oktober, um 8 Uhr, ein.",
                  "timeStart": "18.400",
                  "timeEnd": "24.200",
                  "entities": []
                },
                {
                  "text": "Die Tagesordnung ist auf schriftlichem Wege ergangen.",
                  "timeStart": "24.200",
                  "timeEnd": "27.180",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates berufe ich für Dienstag, den 4. Oktober, um 8 Uhr, ein. Die Tagesordnung ist auf schriftlichem Wege ergangen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Weiters gebe ich bekannt, dass eine halbe Stunde nach Schluss dieser Sitzung der Wissenschaftsausschuss im Lokal 7 zusammentritt.",
                  "timeStart": "27.180",
                  "timeEnd": "35.080",
                  "entities": [
                    {
                      "label": "Wissenschaftsausschuss",
                      "wid": "Q7889981",
                      "wtype": "MISC",
                      "score": 0.3049
                    }
                  ]
                }
              ],
              "text": "Weiters gebe ich bekannt, dass eine halbe Stunde nach Schluss dieser Sitzung der Wissenschaftsausschuss im Lokal 7 zusammentritt."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "35.080",
                  "timeEnd": "37.960",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
