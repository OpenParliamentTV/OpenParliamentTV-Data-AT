              ],
              "text": "Mag. Klaus Fürlinger , Mag. Wolfgang Gerstl , Mag. Ernst Gödl , Kira Grünberg , Mag. Michael Hammer , Peter Haubner , Rebecca Kirchbaumer , August Wöginger , Bettina Zopf von der ÖVP, Dr. Dagmar Belakowitsch , Rosa Ecker, MBA , Dr. Susanne Fürst , Peter Schmiedlechner , Peter Wurm von der FPÖ, Mag. Georg Bürstmayr , Mag. Markus Koza , Sigrid Maurer, BA , Ralph Schallmeiner von den Grünen, Douglas Hoyos-Trauttmansdorff und Dr. Nikolaus Scherak, MA von den NEOS."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die übrigen Abgeordneten dieser Klubs gelten als entschuldigt.",
                  "timeStart": "19.640",
                  "timeEnd": "20.340",
                  "entities": []
                }
              ],
              "text": "Die übrigen Abgeordneten dieser Klubs gelten als entschuldigt."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Seitens der SPÖ wurden folgende Abgeordnete als verhindert gemeldet – und zwar für diese Sitzung –: Cornelia Ecker und Ing. Reinhold Einwallner .",
                  "timeStart": "20.340",
                  "timeEnd": "25.360",
                  "entities": [
                    {
                      "label": "SPÖ",
                      "wid": "Q179111",
                      "wtype": "ORG",
                      "score": 0.7304
                    },
                    {
                      "label": "Cornelia Ecker",
                      "wid": "Q15616501",
                      "wtype": "PER",
                      "score": 0.983
                    }
                  ]
                }
              ],
              "text": "Seitens der SPÖ wurden folgende Abgeordnete als verhindert gemeldet – und zwar für diese Sitzung –: Cornelia Ecker und Ing. Reinhold Einwallner ."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen",
                  "timeStart": "25.360",
                  "timeEnd": "25.480",
                  "entities": []
                }
              ],
              "text": "Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich weise die Regierungsvorlage 608 der Beilagen dem Gesundheitsausschuss sowie die Regierungsvorlage 609 der Beilagen dem Außenpolitischen Ausschuss zu.",
                  "timeStart": "25.480",
                  "timeEnd": "28.080",
                  "entities": []
                }
              ],
              "text": "Ich weise die Regierungsvorlage 608 der Beilagen dem Gesundheitsausschuss sowie die Regierungsvorlage 609 der Beilagen dem Außenpolitischen Ausschuss zu."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich weise die Anträge 1192/A bis 1195/A dem Ausschuss für Arbeit und Soziales zu.",
                  "timeStart": "28.080",
                  "timeEnd": "32.320",
                  "entities": []
                }
              ],
              "text": "Ich weise die Anträge 1192/A bis 1195/A dem Ausschuss für Arbeit und Soziales zu."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Weiters weise ich die Anträge 1196/A bis 1198/A dem Gesundheitsausschuss zu.",
                  "timeStart": "32.320",
                  "timeEnd": "35.940",
                  "entities": []
                }
              ],
              "text": "Weiters weise ich die Anträge 1196/A bis 1198/A dem Gesundheitsausschuss zu."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates berufe ich für heute, Montag, den 21. Dezember 2020, um 12.30 Uhr, ein.",
                  "timeStart": "35.940",
                  "timeEnd": "43.800",
                  "entities": []
                },
                {
                  "text": "Die Tagesordnung ergeht auf schriftlichem Wege.",
                  "timeStart": "43.800",
                  "timeEnd": "45.480",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates berufe ich für heute, Montag, den 21. Dezember 2020, um 12.30 Uhr, ein. Die Tagesordnung ergeht auf schriftlichem Wege."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "45.480",
                  "timeEnd": "48.000",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
