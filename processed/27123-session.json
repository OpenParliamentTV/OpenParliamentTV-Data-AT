                      "score": 0.9744
                    },
                    {
                      "label": "Alois Kainz",
                      "wid": "Q46974794",
                      "wtype": "PER",
                      "score": 0.9637
                    }
                  ]
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Mag. Martin Engelberg , Karlheinz Kopf , Mag. Maria Smodics-Neumann , Dr. Christian Stocker , Cornelia Ecker , Dietmar Keck , Katharina Kucharowits , Rosa Ecker, MBA und Alois Kainz ."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Einlauf und Zuweisungen",
                  "timeStart": "7.120",
                  "timeEnd": "7.640",
                  "entities": []
                }
              ],
              "text": "Einlauf und Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung.",
                  "timeStart": "7.640",
                  "timeEnd": "9.800",
                  "entities": []
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "9.800",
                  "timeEnd": "10.120",
                  "entities": []
                }
              ],
              "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "10.120",
                  "timeEnd": "10.240",
                  "entities": []
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "zur Vorberatung:",
                  "timeStart": "10.240",
                  "timeEnd": "10.720",
                  "entities": []
                }
              ],
              "text": "zur Vorberatung:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Ausschuss für Forschung, Innovation und Digitalisierung:",
                  "timeStart": "10.720",
                  "timeEnd": "11.040",
                  "entities": []
                }
              ],
              "text": "Ausschuss für Forschung, Innovation und Digitalisierung:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem ein Telekommunikationsgesetz erlassen (Telekommunikationsgesetz 2021",
                  "timeStart": "11.040",
                  "timeEnd": "13.600",
                  "entities": []
                },
                {
                  "text": "TKG 2021), das KommAustria-Gesetz (KommAustria-Gesetz",
                  "timeStart": "13.600",
                  "timeEnd": "15.400",
                  "entities": [
                    {
                      "label": "TKG",
                      "wid": "Q2401732",
                      "wtype": "MISC",
                      "score": 0.3607
                    }
                  ]
                },
                {
                  "text": "KOG), die Strafprozeßordnung 1975 (StPO), das Polizeikooperationsgesetz (PolKG), das Polizeiliche Staatsschutzgesetz (PStSG), das Sicherheitspolizeigesetz (SPG), das Wertpapieraufsichtsgesetz 2018 (WAG 2018), das Börsegesetz 2018 (BörseG 2018), das Postmarktgesetz (PMG), das Kraftfahrgesetz 1967 (KFG 1967), das Funkanlagen-Marktüberwachungs-Gesetz (FMAG 2016), das Funker-Zeugnisgesetz 1998 (FZG), das Rundfunkgebührengesetz (RGG), das Fernsprechentgeltzuschussgesetz (FeZG) und das Audiovisuelle Mediendienste-Gesetz (AMD-G) geändert werden ( 1043 d.B. )",
                  "timeStart": "15.400",
                  "timeEnd": "28.680",
                  "entities": [
                    {
                      "label": "KOG",
                      "wid": "Q1770909",
                      "wtype": "ORG",
                      "score": 0.1556
                    },
                    {
                      "label": "StPO",
                      "wid": "Q897021",
                      "wtype": "LOC",
                      "score": 0.5628
                    },
                    {
                      "label": "Polizeiliche Staatsschutzgesetz",
                      "wid": "Q23689498",
                      "wtype": "MISC",
                      "score": 0.9772
                    },
                    {
                      "label": "Sicherheitspolizeigesetz",
                      "wid": "Q2281293",
                      "wtype": "MISC",
                      "score": 0.8721
                    },
                    {
                      "label": "SPG",
                      "wid": "Q2281293",
                      "wtype": "ORG",
                      "score": 0.2287
                    },
                    {
                      "label": "WAG",
                      "wid": "Q1587985",
                      "wtype": "ORG",
                      "score": 0.2726
                    },
                    {
                      "label": "PMG",
                      "wid": "Q372314",
                      "wtype": "MISC",
                      "score": 0.234
                    },
                    {
                      "label": "KFG",
                      "wid": "Q1481818",
                      "wtype": "ORG",
                      "score": 0.5117
                    },
                    {
                      "label": "FZG",
                      "wid": "Q56651755",
                      "wtype": "ORG",
                      "score": 0.139
                    }
                  ]
                }
              ],
              "text": "Bundesgesetz, mit dem ein Telekommunikationsgesetz erlassen (Telekommunikationsgesetz 2021 – TKG 2021), das KommAustria-Gesetz (KommAustria-Gesetz – KOG), die Strafprozeßordnung 1975 (StPO), das Polizeikooperationsgesetz (PolKG), das Polizeiliche Staatsschutzgesetz (PStSG), das Sicherheitspolizeigesetz (SPG), das Wertpapieraufsichtsgesetz 2018 (WAG 2018), das Börsegesetz 2018 (BörseG 2018), das Postmarktgesetz (PMG), das Kraftfahrgesetz 1967 (KFG 1967), das Funkanlagen-Marktüberwachungs-Gesetz (FMAG 2016), das Funker-Zeugnisgesetz 1998 (FZG), das Rundfunkgebührengesetz (RGG), das Fernsprechentgeltzuschussgesetz (FeZG) und das Audiovisuelle Mediendienste-Gesetz (AMD-G) geändert werden ( 1043 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Unterrichtsausschuss:",
                  "timeStart": "28.680",
                  "timeEnd": "29.040",
                  "entities": []
                }
              ],
              "text": "Unterrichtsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Bundesgrundsatzgesetz, mit dem das Bundesgesetz über die Grundsätze betreffend die fachlichen Anstellungserfordernisse für Kindergärtnerinnen und Erzieher geändert wird ( 1042 d.B. )",
                  "timeStart": "29.040",
                  "timeEnd": "30.960",
                  "entities": []
                }
              ],
              "text": "Bundesgrundsatzgesetz, mit dem das Bundesgesetz über die Grundsätze betreffend die fachlichen Anstellungserfordernisse für Kindergärtnerinnen und Erzieher geändert wird ( 1042 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 13. Oktober 2021, 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden.",
                  "timeStart": "30.960",
                  "timeEnd": "33.020",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 13. Oktober 2021, 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Kommen Sie gut nach Hause!",
                  "timeStart": "33.020",
                  "timeEnd": "33.640",
                  "entities": []
                }
              ],
              "text": "Kommen Sie gut nach Hause!"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "speakerID": "35521",
              "sentences": [
                {
                  "text": "Diese Sitzung ist geschlossen.",
                  "timeStart": "33.640",
                  "timeEnd": "36.000",
                  "entities": []
                }
              ],
              "text": "Diese Sitzung ist geschlossen."
