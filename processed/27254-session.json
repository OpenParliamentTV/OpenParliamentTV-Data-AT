              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich eröffne die 254. Sitzung des Nationalrates.",
                  "timeStart": "1.000",
                  "timeEnd": "3.120",
                  "entities": []
                }
              ],
              "text": "Ich eröffne die 254. Sitzung des Nationalrates."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Mag.",
                  "timeStart": "3.120",
                  "timeEnd": "4.600",
                  "entities": []
                },
                {
                  "text": "Dr. Juliane Bogner-Strauß , Mag.",
                  "timeStart": "4.600",
                  "timeEnd": "5.480",
                  "entities": [
                    {
                      "label": "Juliane Bogner-Strauß",
                      "wid": "Q42303930",
                      "wtype": "PER",
                      "score": 0.9938
                    }
                  ]
                },
                {
                  "text": "Johanna Jachs , Ing. Klaus Lindinger, BSc , Julia Elisabeth Herr , Dr. Harald Troch , Mag.",
                  "timeStart": "5.480",
                  "timeEnd": "9.240",
                  "entities": [
                    {
                      "label": "Johanna Jachs",
                      "wid": "Q42305634",
                      "wtype": "PER",
                      "score": 0.988
                    },
                    {
                      "label": "Harald Troch",
                      "wid": "Q1584792",
                      "wtype": "PER",
                      "score": 0.977
                    }
                  ]
                },
                {
                  "text": "Gerhard Kaniak , Wolfgang Zanger und Heike Grebien .",
                  "timeStart": "9.240",
                  "timeEnd": "10.800",
                  "entities": [
                    {
                      "label": "Gerhard Kaniak",
                      "wid": "Q42307034",
                      "wtype": "PER",
                      "score": 0.9845
                    },
                    {
                      "label": "Wolfgang Zanger",
                      "wid": "Q2591817",
                      "wtype": "PER",
                      "score": 0.979
                    },
                    {
                      "label": "Heike Grebien",
                      "wid": "Q81616173",
                      "wtype": "PER",
                      "score": 0.9846
                    }
                  ]
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Mag. Dr. Juliane Bogner-Strauß , Mag. Johanna Jachs , Ing. Klaus Lindinger, BSc , Julia Elisabeth Herr , Dr. Harald Troch , Mag. Gerhard Kaniak , Wolfgang Zanger und Heike Grebien ."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Einlauf und Zuweisungen",
                  "timeStart": "10.800",
                  "timeEnd": "11.600",
                  "entities": []
                }
              ],
              "text": "Einlauf und Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung.",
                  "timeStart": "11.600",
                  "timeEnd": "18.520",
                  "entities": []
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "18.520",
                  "timeEnd": "19.800",
                  "entities": []
                }
              ],
              "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "19.800",
                  "timeEnd": "20.520",
                  "entities": []
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "zur Vorberatung:",
                  "timeStart": "20.520",
                  "timeEnd": "21.000",
                  "entities": []
                }
              ],
              "text": "zur Vorberatung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Justizausschuss:",
                  "timeStart": "21.000",
                  "timeEnd": "21.440",
                  "entities": []
                }
              ],
              "text": "Justizausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem zur Lösung haftungsrechtlicher Fragen bei Bäumen das allgemeine bürgerliche Gesetzbuch geändert wird (Haftungsrechts-Änderungsgesetz 2024 – HaftRÄG 2024) ( 2462 d.B. )",
                  "timeStart": "21.440",
                  "timeEnd": "25.480",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem zur Lösung haftungsrechtlicher Fragen bei Bäumen das allgemeine bürgerliche Gesetzbuch geändert wird (Haftungsrechts-Änderungsgesetz 2024 – HaftRÄG 2024) ( 2462 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Kulturausschuss:",
                  "timeStart": "25.480",
                  "timeEnd": "26.320",
                  "entities": []
                }
              ],
              "text": "Kulturausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Denkmalschutzgesetz geändert wird ( 2463 d.B. )",
                  "timeStart": "26.320",
                  "timeEnd": "27.720",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem das Denkmalschutzgesetz geändert wird ( 2463 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Wissenschaftsausschuss:",
                  "timeStart": "27.720",
                  "timeEnd": "27.960",
                  "entities": [
                    {
                      "label": "Wissenschaftsausschuss",
                      "wid": "Q7889981",
                      "wtype": "MISC",
                      "score": 0.3049
                    }
                  ]
                }
              ],
              "text": "Wissenschaftsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz über das Institute of Digital Sciences Austria (Interdisciplinary Transformation University) ( 2461 d.B. )",
                  "timeStart": "27.960",
                  "timeEnd": "29.320",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz über das Institute of Digital Sciences Austria (Interdisciplinary Transformation University) ( 2461 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 20. März 2024, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden.",
                  "timeStart": "29.320",
                  "timeEnd": "32.160",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 20. März 2024, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich darf weiters bekannt geben, dass im Anschluss an diese Sitzung zunächst der Cofag-Untersuchungsausschuss und danach der Rot-blauer-Machtmissbrauch-Untersuchungsausschuss jeweils im Lokal 1 zusammentritt.",
                  "timeStart": "32.160",
                  "timeEnd": "41.760",
                  "entities": []
                }
              ],
              "text": "Ich darf weiters bekannt geben, dass im Anschluss an diese Sitzung zunächst der Cofag-Untersuchungsausschuss und danach der Rot-blauer-Machtmissbrauch-Untersuchungsausschuss jeweils im Lokal 1 zusammentritt."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "41.760",
                  "timeEnd": "45.960",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
        }
