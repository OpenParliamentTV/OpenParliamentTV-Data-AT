          "textBody": [
            {
              "type": "speech",
              "speaker": null,
              "speakerstatus": null,
              "sentences": [
                {
                  "text": "Beschluss auf Beendigung der außerordentlichen Tagung 2021",
                  "timeStart": "1.000",
                  "timeEnd": "4.080",
                  "entities": []
                }
              ],
              "text": "Beschluss auf Beendigung der außerordentlichen Tagung 2021"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Es liegt mir folgender Antrag der Abgeordneten Wöginger, Maurer, Leichtfried, Belakowitsch und Scherak vor:",
                  "timeStart": "4.080",
                  "timeEnd": "8.020",
                  "entities": []
                }
              ],
              "text": "Es liegt mir folgender Antrag der Abgeordneten Wöginger, Maurer, Leichtfried, Belakowitsch und Scherak vor:"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "„Der Herr Bundespräsident wird ersucht, die außerordentliche Tagung vom 19. Juli 2021 der XXVII.",
                  "timeStart": "8.020",
                  "timeEnd": "17.080",
                  "entities": []
                },
                {
                  "text": "Gesetzgebungsperiode des Nationalrates mit Ablauf des 19. Juli 2021 für beendet zu erklären.“",
                  "timeStart": "17.080",
                  "timeEnd": "26.240",
                  "entities": []
                }
              ],
              "text": "„Der Herr Bundespräsident wird ersucht, die außerordentliche Tagung vom 19. Juli 2021 der XXVII. Gesetzgebungsperiode des Nationalrates mit Ablauf des 19. Juli 2021 für beendet zu erklären.“"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Ich bitte jene Damen und Herren, die diesem Antrag zustimmen, um ein entsprechendes Zeichen. –",
                  "timeStart": "26.240",
                  "timeEnd": "31.680",
                  "entities": []
                },
                {
                  "text": "Das ist einstimmig angenommen.",
                  "timeStart": "35.320",
                  "timeEnd": "40.000",
                  "entities": []
                }
              ],
              "text": "Ich bitte jene Damen und Herren, die diesem Antrag zustimmen, um ein entsprechendes Zeichen. – Das ist einstimmig angenommen."
            }
          ]
        }
      ],
