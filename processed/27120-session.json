          "originTextID": "251795",
          "textBody": [
            {
              "type": "speech",
              "speaker": null,
              "speakerstatus": null,
              "sentences": [
                {
                  "text": "Verlesung eines Teiles des Amtlichen Protokolls",
                  "timeStart": "1.000",
                  "timeEnd": "3.160",
                  "entities": []
                }
              ],
              "text": "Verlesung eines Teiles des Amtlichen Protokolls"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Um eine umgehende Ausfertigung dieses Beschlusses zu ermöglichen, verlese ich entsprechend einem schriftlichen Verlangen von 20 Abgeordneten den diesbezüglichen Teil des Amtlichen Protokolls, damit dieser mit Schluss der Sitzung als genehmigt gilt.",
                  "timeStart": "3.160",
                  "timeEnd": "17.700",
                  "entities": []
                }
              ],
              "text": "Um eine umgehende Ausfertigung dieses Beschlusses zu ermöglichen, verlese ich entsprechend einem schriftlichen Verlangen von 20 Abgeordneten den diesbezüglichen Teil des Amtlichen Protokolls, damit dieser mit Schluss der Sitzung als genehmigt gilt."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Ich verlese:",
                  "timeStart": "17.700",
                  "timeEnd": "19.220",
                  "entities": []
                }
              ],
              "text": "Ich verlese:"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "„Auf Antrag der Abgeordneten Wöginger, Maurer, BA, Mag.",
                  "timeStart": "19.220",
                  "timeEnd": "22.840",
                  "entities": []
                },
                {
                  "text": "Leichtfried, Dr. Belakowitsch und Dr. Scherak, MA [...] fasst der Nationalrat [...] nachstehenden Beschluss:",
                  "timeStart": "22.840",
                  "timeEnd": "27.840",
                  "entities": []
                }
              ],
              "text": "„Auf Antrag der Abgeordneten Wöginger, Maurer, BA, Mag. Leichtfried, Dr. Belakowitsch und Dr. Scherak, MA [...] fasst der Nationalrat [...] nachstehenden Beschluss:"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": ",Der Herr Bundespräsident wird ersucht, die außerordentliche Tagung vom 19. Juli 2021 der XXVII.",
                  "timeStart": "27.840",
                  "timeEnd": "36.000",
                  "entities": []
                },
                {
                  "text": "Gesetzgebungsperiode des Nationalrates mit Ablauf des 19. Juli 2021 für beendet zu erklären.‘“",
                  "timeStart": "36.000",
                  "timeEnd": "44.160",
                  "entities": []
                }
              ],
              "text": ",Der Herr Bundespräsident wird ersucht, die außerordentliche Tagung vom 19. Juli 2021 der XXVII. Gesetzgebungsperiode des Nationalrates mit Ablauf des 19. Juli 2021 für beendet zu erklären.‘“"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Erheben sich Einwendungen gegen die Fassung oder den Inhalt des Amtlichen Protokolls? –",
                  "timeStart": "44.160",
                  "timeEnd": "50.140",
                  "entities": []
                },
                {
                  "text": "Das ist nicht der Fall.",
                  "timeStart": "50.140",
                  "timeEnd": "52.040",
                  "entities": []
                }
              ],
              "text": "Erheben sich Einwendungen gegen die Fassung oder den Inhalt des Amtlichen Protokolls? – Das ist nicht der Fall."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Dieser Teil des Amtlichen Protokolls gilt daher gemäß § 51 Abs. 6 der Geschäftsordnung mit Schluss dieser Sitzung als genehmigt.",
                  "timeStart": "52.040",
                  "timeEnd": "61.900",
                  "entities": []
                }
              ],
              "text": "Dieser Teil des Amtlichen Protokolls gilt daher gemäß § 51 Abs. 6 der Geschäftsordnung mit Schluss dieser Sitzung als genehmigt."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 22. September, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden.",
                  "timeStart": "61.900",
                  "timeEnd": "71.540",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 22. September, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Ich wünsche Ihnen einen schönen und erholsamen Sommer.",
                  "timeStart": "71.540",
                  "timeEnd": "76.520",
                  "entities": []
                }
              ],
              "text": "Ich wünsche Ihnen einen schönen und erholsamen Sommer."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "76.520",
                  "timeEnd": "80.000",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
        }
