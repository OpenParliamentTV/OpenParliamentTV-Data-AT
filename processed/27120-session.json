      "textContents": [
        {
          "type": "proceedings",
          "sourceURI": "https://www.parlament.gv.at/dokument/XXVII/NRSITZ/120/A_-_14_39_25_00251795.html",
          "creator": "Parlamentsdirektion / Parlament Österreich",
          "license": "CC-BY-4.0",
