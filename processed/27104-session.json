              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich eröffne die 104. Sitzung des Nationalrates.",
                  "timeStart": "1.000",
                  "timeEnd": "2.700"
                }
              ],
              "text": "Ich eröffne die 104. Sitzung des Nationalrates."
