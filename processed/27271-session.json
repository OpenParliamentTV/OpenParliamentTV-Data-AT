          "textBody": [
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich eröffne die 271. Sitzung des Nationalrates.",
                  "timeStart": "1.000",
                  "timeEnd": "3.000",
                  "entities": []
                }
              ],
              "text": "Ich eröffne die 271. Sitzung des Nationalrates."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Martina Kaufmann, MMSc BA , Dr. Gudrun Kugler , Mag.",
                  "timeStart": "3.000",
                  "timeEnd": "3.320",
                  "entities": []
                },
                {
                  "text": "Muna Duzdar , Elisabeth Feichtinger, BEd BEd , Maximilian Lercher , Christian Lausch und Bedrana Ribo, MA .",
                  "timeStart": "3.320",
                  "timeEnd": "3.320",
                  "entities": []
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Martina Kaufmann, MMSc BA , Dr. Gudrun Kugler , Mag. Muna Duzdar , Elisabeth Feichtinger, BEd BEd , Maximilian Lercher , Christian Lausch und Bedrana Ribo, MA ."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Einlauf und Zuweisungen",
                  "timeStart": "3.320",
                  "timeEnd": "3.320",
                  "entities": []
                }
              ],
              "text": "Einlauf und Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung.",
                  "timeStart": "3.320",
                  "timeEnd": "5.400",
                  "entities": []
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "5.400",
                  "timeEnd": "5.400",
                  "entities": []
                }
              ],
              "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "5.400",
                  "timeEnd": "5.480",
                  "entities": []
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "a) zur Vorberatung:",
                  "timeStart": "5.480",
                  "timeEnd": "5.680",
                  "entities": []
                }
              ],
              "text": "a) zur Vorberatung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Budgetausschuss:",
                  "timeStart": "5.680",
                  "timeEnd": "5.720",
                  "entities": []
                }
              ],
              "text": "Budgetausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Antrag der Abgeordneten Mag.",
                  "timeStart": "5.720",
                  "timeEnd": "6.360",
                  "entities": []
                },
                {
                  "text": "Verena Nussbaum , Kolleginnen und Kollegen betreffend Indexierung der pauschalen Freibeträge für außergewöhnliche Belastungen und aufgrund von Behinderungen ( 4137/A(E) )",
                  "timeStart": "6.360",
                  "timeEnd": "10.040",
                  "entities": []
                }
              ],
              "text": "Antrag der Abgeordneten Mag. Verena Nussbaum , Kolleginnen und Kollegen betreffend Indexierung der pauschalen Freibeträge für außergewöhnliche Belastungen und aufgrund von Behinderungen ( 4137/A(E) )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Verkehrsausschuss:",
                  "timeStart": "10.040",
                  "timeEnd": "10.960",
                  "entities": []
                }
              ],
              "text": "Verkehrsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Antrag der Abgeordneten Alois Stöger, diplômé , Kolleginnen und Kollegen betreffend ein Bundesgesetz, mit dem der besondere Arbeitnehmerschutz in Verkehrsbetrieben erlassen wird (ANSV-G) und das Bundesgesetz über die Ordnung des öffentlichen Personennah-und Regionalverkehrs – ÖPNRV-G 1999 BGBI I 204/1999 geändert wird ( 4136/A )",
                  "timeStart": "10.960",
                  "timeEnd": "25.520",
                  "entities": []
                }
              ],
              "text": "Antrag der Abgeordneten Alois Stöger, diplômé , Kolleginnen und Kollegen betreffend ein Bundesgesetz, mit dem der besondere Arbeitnehmerschutz in Verkehrsbetrieben erlassen wird (ANSV-G) und das Bundesgesetz über die Ordnung des öffentlichen Personennah-und Regionalverkehrs – ÖPNRV-G 1999 BGBI I 204/1999 geändert wird ( 4136/A )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "b) zur Enderledigung im Sinne des § 28b GOG (vorbehaltlich der endgültigen Entscheidung des Ausschusses):",
                  "timeStart": "25.520",
                  "timeEnd": "27.640",
                  "entities": []
                }
              ],
              "text": "b) zur Enderledigung im Sinne des § 28b GOG (vorbehaltlich der endgültigen Entscheidung des Ausschusses):"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Verkehrsausschuss:",
                  "timeStart": "27.640",
                  "timeEnd": "28.440",
                  "entities": []
                }
              ],
              "text": "Verkehrsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Tätigkeitsbericht der Schienen-Control GmbH 2023, vorgelegt von der Bundesministerin für Klimaschutz, Umwelt, Energie, Mobilität, Innovation und Technologie ( III-1193 d.B. )",
                  "timeStart": "28.440",
                  "timeEnd": "34.280",
                  "entities": []
                }
              ],
              "text": "Tätigkeitsbericht der Schienen-Control GmbH 2023, vorgelegt von der Bundesministerin für Klimaschutz, Umwelt, Energie, Mobilität, Innovation und Technologie ( III-1193 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Fristsetzungsantrag",
                  "timeStart": "34.280",
                  "timeEnd": "35.560",
                  "entities": []
                }
              ],
              "text": "Fristsetzungsantrag"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich teile mit, dass die Abgeordneten Stocker, Bürstmayr beantragt haben, dem Ausschuss für innere Angelegenheiten zur Berichterstattung über die Regierungsvorlage 2657 der Beilagen : Grundversorgungsänderungsvereinbarung, eine Frist bis zum 4. Juli zu setzen.",
                  "timeStart": "35.560",
                  "timeEnd": "41.080",
                  "entities": []
                }
              ],
              "text": "Ich teile mit, dass die Abgeordneten Stocker, Bürstmayr beantragt haben, dem Ausschuss für innere Angelegenheiten zur Berichterstattung über die Regierungsvorlage 2657 der Beilagen : Grundversorgungsänderungsvereinbarung, eine Frist bis zum 4. Juli zu setzen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Der gegenständliche Antrag wird gemäß der Geschäftsordnung nach Beendigung der Verhandlungen in dieser Sitzung, das heißt also sogleich, zur Abstimmung gebracht.",
                  "timeStart": "41.080",
                  "timeEnd": "46.000",
                  "entities": []
                }
              ],
              "text": "Der gegenständliche Antrag wird gemäß der Geschäftsordnung nach Beendigung der Verhandlungen in dieser Sitzung, das heißt also sogleich, zur Abstimmung gebracht."
            }
          ]
        }
