            {
              "type": "speech",
              "speaker": null,
              "speakerstatus": null,
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates berufe ich für Donnerstag, den 4. Juli, um 9 Uhr ein.",
                  "timeStart": "1.000",
                  "timeEnd": "5.520",
                  "entities": []
                },
                {
                  "text": "Die Tagesordnung ist bereits auf schriftlichem Wege ergangen.",
                  "timeStart": "5.520",
                  "timeEnd": "10.040",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates berufe ich für Donnerstag, den 4. Juli, um 9 Uhr ein. Die Tagesordnung ist bereits auf schriftlichem Wege ergangen."
            },
            {
              "type": "speech",
              "speaker": null,
              "speakerstatus": null,
              "sentences": [
                {
                  "text": "Kommen Sie gut nach Hause oder feiern Sie ausgiebig die nächsten Stunden bis zum Beginn der nächsten Sitzung um 9 Uhr.",
                  "timeStart": "10.040",
                  "timeEnd": "18.840",
                  "entities": []
                }
              ],
              "text": "Kommen Sie gut nach Hause oder feiern Sie ausgiebig die nächsten Stunden bis zum Beginn der nächsten Sitzung um 9 Uhr."
            },
            {
              "type": "speech",
              "speaker": null,
              "speakerstatus": null,
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "18.840",
                  "timeEnd": "21.360",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
