          "textBody": [
            {
              "type": "speech",
              "speaker": null,
              "speakerstatus": null,
              "sentences": [
                {
                  "text": "Abstimmung über einen Fristsetzungsantrag",
                  "timeStart": "1.000",
                  "timeEnd": "5.040",
                  "entities": []
                }
              ],
              "text": "Abstimmung über einen Fristsetzungsantrag"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Wir kommen daher zur Abstimmung über den soeben erwähnten Fristsetzungsantrag.",
                  "timeStart": "5.040",
                  "timeEnd": "8.680",
                  "entities": []
                }
              ],
              "text": "Wir kommen daher zur Abstimmung über den soeben erwähnten Fristsetzungsantrag."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich bitte die Damen und Herren, die diesem Fristsetzungsantrag die Zustimmung geben, um ein dementsprechendes Zeichen. –",
                  "timeStart": "8.680",
                  "timeEnd": "14.120",
                  "entities": []
                },
                {
                  "text": "Das ist die Mehrheit, angenommen.",
                  "timeStart": "14.120",
                  "timeEnd": "16.000",
                  "entities": []
                }
              ],
              "text": "Ich bitte die Damen und Herren, die diesem Fristsetzungsantrag die Zustimmung geben, um ein dementsprechendes Zeichen. – Das ist die Mehrheit, angenommen."
            }
          ]
        }
      ],
