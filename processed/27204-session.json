                      "score": 0.8161
                    }
                  ]
                }
              ],
              "text": "Bundesgesetz, mit dem das Patentverträge-Einführungsgesetz, das Patentgesetz 1970, das Gebrauchsmustergesetz, das Markenschutzgesetz 1970, das Musterschutzgesetz 1990 und das Patentamtsgebührengesetz geändert werden ( 1955 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Unterrichtsausschuss:",
                  "timeStart": "25.480",
                  "timeEnd": "25.880",
                  "entities": []
                }
              ],
              "text": "Unterrichtsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Schulorganisationsgesetz, das Schulunterrichtsgesetz, das Schulpflichtgesetz 1985, das Pflichtschulerhaltungs-Grundsatzgesetz und das COVID-19-Hochschulgesetzes – C-HG geändert werden ( 1956 d.B. )",
                  "timeStart": "25.880",
                  "timeEnd": "33.960",
                  "entities": [
                    {
                      "label": "Bundesgesetz",
                      "wid": "Q476068",
                      "wtype": "MISC",
                      "score": 0.0943
                    },
                    {
                      "label": "Schulorganisationsgesetz",
                      "wid": "Q18412933",
                      "wtype": "MISC",
                      "score": 0.8842
                    }
                  ]
                }
              ],
              "text": "Bundesgesetz, mit dem das Schulorganisationsgesetz, das Schulunterrichtsgesetz, das Schulpflichtgesetz 1985, das Pflichtschulerhaltungs-Grundsatzgesetz und das COVID-19-Hochschulgesetzes – C-HG geändert werden ( 1956 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Verkehrsausschuss:",
                  "timeStart": "33.960",
                  "timeEnd": "34.600",
                  "entities": []
                }
              ],
              "text": "Verkehrsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Kraftfahrgesetz 1967 geändert wird (41. KFG-Novelle) ( 1954 d.B. )",
                  "timeStart": "34.600",
                  "timeEnd": "37.760",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem das Kraftfahrgesetz 1967 geändert wird (41. KFG-Novelle) ( 1954 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 29. März, 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden.",
                  "timeStart": "37.760",
                  "timeEnd": "41.280",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 29. März, 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Ich wünsche Ihnen allen eine schöne gute Nacht.",
                  "timeStart": "41.280",
                  "timeEnd": "41.720",
                  "entities": []
                }
              ],
              "text": "Ich wünsche Ihnen allen eine schöne gute Nacht."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "41.720",
                  "timeEnd": "41.960",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
