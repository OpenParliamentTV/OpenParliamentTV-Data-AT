          "textBody": [
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Ich eröffne die 204. Sitzung, Donnerstag, 2. März, 0.54 Uhr.",
                  "timeStart": "1.000",
                  "timeEnd": "1.960",
                  "entities": []
                }
              ],
              "text": "Ich eröffne die 204. Sitzung, Donnerstag, 2. März, 0.54 Uhr."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Mag.",
                  "timeStart": "1.960",
                  "timeEnd": "3.440",
                  "entities": []
                },
                {
                  "text": "Peter Weidinger , Katharina Kucharowits , Dr. Susanne Fürst , Michael Schnedlitz , Heike Grebien und Dipl.-Ing. Olga Voglauer .",
                  "timeStart": "3.440",
                  "timeEnd": "4.440",
                  "entities": [
                    {
                      "label": "Peter Weidinger",
                      "wid": "Q42941654",
                      "wtype": "PER",
                      "score": 0.9754
                    },
                    {
                      "label": "Katharina Kucharowits",
                      "wid": "Q15823205",
                      "wtype": "PER",
                      "score": 0.9823
                    },
                    {
                      "label": "Susanne Fürst",
                      "wid": "Q42295912",
                      "wtype": "PER",
                      "score": 0.9797
                    },
                    {
                      "label": "Michael Schnedlitz",
                      "wid": "Q51000135",
                      "wtype": "PER",
                      "score": 0.989
                    },
                    {
                      "label": "Heike Grebien",
                      "wid": "Q81616173",
                      "wtype": "PER",
                      "score": 0.9846
                    }
                  ]
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Mag. Peter Weidinger , Katharina Kucharowits , Dr. Susanne Fürst , Michael Schnedlitz , Heike Grebien und Dipl.-Ing. Olga Voglauer ."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Zuweisungen",
                  "timeStart": "4.440",
                  "timeEnd": "4.680",
                  "entities": []
                }
              ],
              "text": "Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung.",
                  "timeStart": "4.680",
                  "timeEnd": "8.960",
                  "entities": []
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Die Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "8.960",
                  "timeEnd": "9.760",
                  "entities": []
                }
              ],
              "text": "Die Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "9.760",
                  "timeEnd": "9.960",
                  "entities": []
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
