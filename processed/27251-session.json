          "textBody": [
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die 251. Sitzung des Nationalrates ist eröffnet.",
                  "timeStart": "1.000",
                  "timeEnd": "2.600",
                  "entities": []
                }
              ],
              "text": "Die 251. Sitzung des Nationalrates ist eröffnet."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Maria Großbauer , Nico Marchetti , Julia Elisabeth Herr , Mag.",
                  "timeStart": "2.600",
                  "timeEnd": "5.880",
                  "entities": [
                    {
                      "label": "Maria Großbauer",
                      "wid": "Q28851897",
                      "wtype": "PER",
                      "score": 0.9897
                    },
                    {
                      "label": "Nico Marchetti",
                      "wid": "Q42308049",
                      "wtype": "PER",
                      "score": 0.9846
                    }
                  ]
                },
                {
                  "text": "Gerald Hauser , Heike Grebien , Mag.",
                  "timeStart": "5.880",
                  "timeEnd": "7.320",
                  "entities": [
                    {
                      "label": "Gerald Hauser",
                      "wid": "Q1509909",
                      "wtype": "PER",
                      "score": 0.9832
                    },
                    {
                      "label": "Heike Grebien",
                      "wid": "Q81616173",
                      "wtype": "PER",
                      "score": 0.9846
                    }
                  ]
                },
                {
                  "text": "Nina Tomaselli und Dipl.-Ing. Karin Doppelbauer .",
                  "timeStart": "7.320",
                  "timeEnd": "9.440",
                  "entities": [
                    {
                      "label": "Nina Tomaselli",
                      "wid": "Q18629460",
                      "wtype": "PER",
                      "score": 0.9933
                    }
                  ]
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Maria Großbauer , Nico Marchetti , Julia Elisabeth Herr , Mag. Gerald Hauser , Heike Grebien , Mag. Nina Tomaselli und Dipl.-Ing. Karin Doppelbauer ."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Einlauf und Zuweisungen",
                  "timeStart": "9.440",
                  "timeEnd": "9.880",
                  "entities": []
                }
              ],
              "text": "Einlauf und Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung.",
                  "timeStart": "9.880",
                  "timeEnd": "18.160",
                  "entities": []
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "18.160",
                  "timeEnd": "19.560",
                  "entities": []
                }
              ],
              "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "19.560",
                  "timeEnd": "20.160",
                  "entities": []
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "zur Vorberatung:",
                  "timeStart": "20.160",
                  "timeEnd": "20.760",
                  "entities": []
                }
              ],
              "text": "zur Vorberatung:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Gesundheitsausschuss:",
                  "timeStart": "20.760",
                  "timeEnd": "21.480",
                  "entities": []
                }
              ],
              "text": "Gesundheitsausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Veterinärrechtsnovelle 2024 (2433 d.B.)",
                  "timeStart": "21.480",
                  "timeEnd": "24.640",
                  "entities": []
                }
              ],
              "text": "Veterinärrechtsnovelle 2024 (2433 d.B.)"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Umweltausschuss:",
                  "timeStart": "24.640",
                  "timeEnd": "25.000",
                  "entities": []
                }
              ],
              "text": "Umweltausschuss:"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Altlastensanierungsgesetz, das Umweltförderungsgesetz und das Umweltkontrollgesetz geändert werden (ALSAG-Novelle 2024) ( 2432 d.B. )",
                  "timeStart": "25.000",
                  "timeEnd": "32.560",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem das Altlastensanierungsgesetz, das Umweltförderungsgesetz und das Umweltkontrollgesetz geändert werden (ALSAG-Novelle 2024) ( 2432 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 28. Februar 2024, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden.",
                  "timeStart": "32.560",
                  "timeEnd": "38.640",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 28. Februar 2024, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich gebe weiters bekannt, dass im Anschluss an diese Sitzung der Cofag-Untersuchungsausschuss in Lokal 1 zusammentritt.",
                  "timeStart": "38.640",
                  "timeEnd": "41.280",
                  "entities": []
                },
                {
                  "text": "Wir sehen uns dann dort.",
                  "timeStart": "41.280",
                  "timeEnd": "42.280",
                  "entities": []
                }
              ],
              "text": "Ich gebe weiters bekannt, dass im Anschluss an diese Sitzung der Cofag-Untersuchungsausschuss in Lokal 1 zusammentritt. Wir sehen uns dann dort."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Im Anschluss tritt der Rot-blauer-Machtmissbrauch-Untersuchungsausschuss ebenfalls in Lokal 1 zusammen.",
                  "timeStart": "42.280",
                  "timeEnd": "44.240",
                  "entities": []
                }
              ],
              "text": "Im Anschluss tritt der Rot-blauer-Machtmissbrauch-Untersuchungsausschuss ebenfalls in Lokal 1 zusammen."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "44.240",
                  "timeEnd": "44.760",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
