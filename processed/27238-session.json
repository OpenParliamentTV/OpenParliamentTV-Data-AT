              ],
              "text": "Fristsetzungsanträge"
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Weiters teile ich mit, dass Herr Abgeordneter Kickl, Kolleginnen und Kollegen beantragt haben, dem Verfassungsausschuss zur Berichterstattung über den Antrag 1771/A(E) eine Frist bis zum 26. Oktober 2023 zu setzen.",
                  "timeStart": "66.680",
                  "timeEnd": "83.120",
                  "entities": []
                }
              ],
              "text": "Weiters teile ich mit, dass Herr Abgeordneter Kickl, Kolleginnen und Kollegen beantragt haben, dem Verfassungsausschuss zur Berichterstattung über den Antrag 1771/A(E) eine Frist bis zum 26. Oktober 2023 zu setzen."
            },
            {
              "type": "speech",
              "speaker": "Doris Bures",
              "speakerstatus": "Präsidentin",
              "sentences": [
                {
                  "text": "Weiters teile ich mit, dass Herr Abgeordneter Kickl, Kolleginnen und Kollegen beantragt haben, dem Verfassungsausschuss zur Berichterstattung über den Antrag 3309/A ebenfalls eine Frist bis zum 26. Oktober 2023 zu setzen.",
                  "timeStart": "83.120",
                  "timeEnd": "97.960",
                  "entities": []
                }
              ],
              "text": "Weiters teile ich mit, dass Herr Abgeordneter Kickl, Kolleginnen und Kollegen beantragt haben, dem Verfassungsausschuss zur Berichterstattung über den Antrag 3309/A ebenfalls eine Frist bis zum 26. Oktober 2023 zu setzen."
