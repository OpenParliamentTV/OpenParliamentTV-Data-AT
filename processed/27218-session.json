              ],
              "text": "Abstimmung über Fristsetzungsanträge"
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Wir kommen zur Abstimmung über den Antrag der Abgeordneten Sieber, Koza, Kolleginnen und Kollegen, dem Ausschuss für Familie und Jugend zur Berichterstattung über den Antrag 3430/A eine Frist bis 13. Juni 2023 zu setzen.",
                  "timeStart": "1.640",
                  "timeEnd": "13.120",
                  "entities": []
                }
              ],
              "text": "Wir kommen zur Abstimmung über den Antrag der Abgeordneten Sieber, Koza, Kolleginnen und Kollegen, dem Ausschuss für Familie und Jugend zur Berichterstattung über den Antrag 3430/A eine Frist bis 13. Juni 2023 zu setzen."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich bitte jene Damen und Herren, die für diesen Fristsetzungsantrag sind, um ein Zeichen der Zustimmung. –",
                  "timeStart": "13.120",
                  "timeEnd": "18.560",
                  "entities": []
                },
                {
                  "text": "Das ist mehrheitlich angenommen.",
                  "timeStart": "18.560",
                  "timeEnd": "20.240",
                  "entities": []
                }
              ],
              "text": "Ich bitte jene Damen und Herren, die für diesen Fristsetzungsantrag sind, um ein Zeichen der Zustimmung. – Das ist mehrheitlich angenommen."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Wir kommen nun zur Abstimmung über den Antrag der Abgeordneten Kickl, Kolleginnen und Kollegen, dem Verfassungsausschuss zur Berichterstattung über den Antrag 3066/A eine Frist bis 2. Juni 2023 zu setzen.",
                  "timeStart": "20.240",
                  "timeEnd": "33.280",
                  "entities": [
                    {
                      "label": "Kickl",
                      "wid": "Q1395041",
                      "wtype": "PER",
                      "score": 0.3233
                    }
                  ]
                }
              ],
              "text": "Wir kommen nun zur Abstimmung über den Antrag der Abgeordneten Kickl, Kolleginnen und Kollegen, dem Verfassungsausschuss zur Berichterstattung über den Antrag 3066/A eine Frist bis 2. Juni 2023 zu setzen."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich bitte jene Damen und Herren, die für den Fristsetzungsantrag sind, um ein Zeichen der Zustimmung. –",
                  "timeStart": "33.280",
                  "timeEnd": "38.720",
                  "entities": []
                },
                {
                  "text": "Das ist die Minderheit, der Antrag ist abgelehnt.",
                  "timeStart": "38.720",
                  "timeEnd": "42.040",
                  "entities": []
                }
              ],
              "text": "Ich bitte jene Damen und Herren, die für den Fristsetzungsantrag sind, um ein Zeichen der Zustimmung. – Das ist die Minderheit, der Antrag ist abgelehnt."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 14. Juni 2023, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden.",
                  "timeStart": "42.040",
                  "timeEnd": "51.560",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 14. Juni 2023, um 9 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen werden."
            },
            {
              "type": "speech",
              "speaker": "Norbert Hofer",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen.",
                  "timeStart": "51.560",
                  "timeEnd": "54.000",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen."
            }
          ]
