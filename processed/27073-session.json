              "speakerstatus": "Präsident",
              "speakerID": "88386",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Gesundheitsberuferegister-Gesetz geändert wird (GBRG-Novelle 2020) ( 608 d.B. )",
                  "timeStart": "61.580",
                  "timeEnd": "64.160",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem das Gesundheitsberuferegister-Gesetz geändert wird (GBRG-Novelle 2020) ( 608 d.B. )"
            },
