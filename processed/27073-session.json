              "speakerstatus": "Präsident",
              "speakerID": "88386",
              "sentences": [
                {
                  "text": "Meine sehr geehrten Damen und Herren Abgeordneten!",
                  "timeStart": "1.000",
                  "timeEnd": "6.480",
                  "entities": []
                },
                {
                  "text": "Werte Journalistinnen und Journalisten!",
                  "timeStart": "6.480",
                  "timeEnd": "7.760",
                  "entities": []
                },
                {
                  "text": "Ich darf die 73. Sitzung eröffnen.",
                  "timeStart": "7.760",
                  "timeEnd": "9.880",
                  "entities": []
                }
              ],
              "text": "Meine sehr geehrten Damen und Herren Abgeordneten! Werte Journalistinnen und Journalisten! Ich darf die 73. Sitzung eröffnen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "speakerID": "88386",
              "sentences": [
                {
                  "text": "Die nicht verlesenen Teile des Amtlichen Protokolls der 69. Sitzung sowie das Amtliche Protokoll der 70. Sitzung vom 10. und vom 11. Dezember 2020 und die nicht verlesenen Teile des Amtlichen Protokolls der 71. sowie das Amtliche Protokoll der 72. Sitzung vom 11. Dezember 2020 sind in der Parlamentsdirektion aufgelegen und wurden nicht beanstandet.",
                  "timeStart": "9.880",
                  "timeEnd": "23.420",
                  "entities": [
                    {
                      "label": "Amtliche",
                      "wid": "Q7079603",
                      "wtype": "MISC",
                      "score": 0.0886
                    },
                    {
                      "label": "Amtliche",
