                      "score": 0.4922
                    }
                  ]
                },
                {
                  "text": "Ruth Becher , Cornelia Ecker , Mag.",
                  "timeStart": "4.040",
                  "timeEnd": "4.520",
                  "entities": [
                    {
                      "label": "Ruth Becher",
                      "wid": "Q2177565",
