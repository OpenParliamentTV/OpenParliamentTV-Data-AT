                    },
                    {
                      "label": "Cornelia Ecker",
                      "wid": "Q15616501",
                      "wtype": "PER",
                      "score": 0.9777
                    }
                  ]
                },
                {
                  "text": "Karin Greiner , Gabriele Heinisch-Hosek , Katharina Kucharowits , Rosa Ecker, MBA , Edith Mühlberghuber und Dr. Helmut Brandstätter .",
                  "timeStart": "4.520",
                  "timeEnd": "8.240",
                  "entities": [
                    {
                      "label": "Karin Greiner",
                      "wid": "Q15822812",
                      "wtype": "PER",
                      "score": 0.9576
                    },
                    {
                      "label": "Gabriele Heinisch-Hosek",
                      "wid": "Q90404",
                      "wtype": "PER",
                      "score": 0.9916
                    },
                    {
                      "label": "Katharina Kucharowits",
                      "wid": "Q15823205",
                      "wtype": "PER",
                      "score": 0.9823
                    },
                    {
                      "label": "Rosa Ecker",
                      "wid": "Q21336878",
                      "wtype": "PER",
                      "score": 0.9744
                    },
                    {
                      "label": "Edith Mühlberghuber",
                      "wid": "Q1285098",
                      "wtype": "PER",
                      "score": 0.3601
                    }
                  ]
                }
              ],
              "text": "Als verhindert gemeldet sind die Abgeordneten Mag. Bettina Rausch , Johann Singer , Mag. Ruth Becher , Cornelia Ecker , Mag. Karin Greiner , Gabriele Heinisch-Hosek , Katharina Kucharowits , Rosa Ecker, MBA , Edith Mühlberghuber und Dr. Helmut Brandstätter ."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen",
                  "timeStart": "8.240",
                  "timeEnd": "8.280",
                  "entities": []
                }
              ],
              "text": "Zuweisungen"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung.",
                  "timeStart": "8.280",
                  "timeEnd": "12.360",
                  "entities": []
                }
              ],
              "text": "Hinsichtlich der eingelangten Verhandlungsgegenstände und deren Zuweisungen verweise ich gemäß § 23 Abs. 4 der Geschäftsordnung auf die im Sitzungssaal verteilte Mitteilung."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:",
                  "timeStart": "12.360",
                  "timeEnd": "13.040",
                  "entities": []
                }
              ],
              "text": "Die schriftliche Mitteilung hat folgenden Wortlaut:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Zuweisungen in dieser Sitzung:",
                  "timeStart": "13.040",
                  "timeEnd": "13.840",
                  "entities": []
                }
              ],
              "text": "Zuweisungen in dieser Sitzung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "zur Vorberatung:",
                  "timeStart": "13.840",
                  "timeEnd": "14.440",
                  "entities": []
                }
              ],
              "text": "zur Vorberatung:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ausschuss für Wirtschaft, Industrie und Energie:",
                  "timeStart": "14.440",
                  "timeEnd": "14.960",
                  "entities": []
                }
              ],
              "text": "Ausschuss für Wirtschaft, Industrie und Energie:"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Maschinen – Inverkehrbringungs- und NotifizierungsG (MING), das Elektrotechnikgesetz 1992 – ETG 1992, das Bundesgesetz gegen den unlauteren Wettbewerb 1984 – UWG und die Gewerbeordnung 1994 – GewO 1994 geändert werden ( 1673 d.B. )",
                  "timeStart": "14.960",
                  "timeEnd": "26.160",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem das Maschinen – Inverkehrbringungs- und NotifizierungsG (MING), das Elektrotechnikgesetz 1992 – ETG 1992, das Bundesgesetz gegen den unlauteren Wettbewerb 1984 – UWG und die Gewerbeordnung 1994 – GewO 1994 geändert werden ( 1673 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem die Gewerbeordnung 1994 geändert wird ( 1674 d.B. )",
                  "timeStart": "26.160",
                  "timeEnd": "29.120",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem die Gewerbeordnung 1994 geändert wird ( 1674 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Bundesgesetz, mit dem das Maß- und Eichgesetz geändert wird ( 1675 d.B. )",
                  "timeStart": "29.120",
                  "timeEnd": "30.560",
                  "entities": []
                }
              ],
              "text": "Bundesgesetz, mit dem das Maß- und Eichgesetz geändert wird ( 1675 d.B. )"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 12. Oktober 2022, 10 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen.",
                  "timeStart": "30.560",
                  "timeEnd": "32.480",
                  "entities": []
                }
              ],
              "text": "Die nächste Sitzung des Nationalrates, die für Mittwoch, den 12. Oktober 2022, 10 Uhr, in Aussicht genommen ist, wird auf schriftlichem Wege einberufen."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich wünsche eine gute Nacht, und kommen Sie gut nach Hause!",
                  "timeStart": "32.480",
                  "timeEnd": "34.880",
                  "entities": []
                }
              ],
              "text": "Ich wünsche eine gute Nacht, und kommen Sie gut nach Hause!"
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Die Sitzung ist geschlossen .",
                  "timeStart": "34.880",
                  "timeEnd": "35.320",
                  "entities": []
                }
              ],
              "text": "Die Sitzung ist geschlossen ."
            }
          ]
        }
