          "textBody": [
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Ich eröffne die 173. Sitzung des Nationalrates.",
                  "timeStart": "1.000",
                  "timeEnd": "2.720",
                  "entities": []
                }
              ],
              "text": "Ich eröffne die 173. Sitzung des Nationalrates."
            },
            {
              "type": "speech",
              "speaker": "Wolfgang Sobotka",
              "speakerstatus": "Präsident",
              "sentences": [
                {
                  "text": "Als verhindert gemeldet sind die Abgeordneten Mag.",
                  "timeStart": "2.720",
                  "timeEnd": "3.720",
                  "entities": []
                },
                {
                  "text": "Bettina Rausch , Johann Singer , Mag.",
                  "timeStart": "3.720",
                  "timeEnd": "4.040",
                  "entities": [
                    {
                      "label": "Bettina Rausch",
                      "wid": "Q850023",
                      "wtype": "PER",
                      "score": 0.9823
                    },
                    {
